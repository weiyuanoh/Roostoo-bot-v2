ROOSTOO_API_KEY=
ROOSTOO_API_SECRET=
ROOSTOO_BASE_URL=https://mock-api.roostoo.com

BINANCE_BASE_URL=https://data-api.binance.vision
BINANCE_FALLBACK_URLS=https://data-api.binance.vision,https://api.binance.com

REQUEST_TIMEOUT_SECONDS=10
LOG_LEVEL=INFO
BOT_LOG_CONSOLE=1

LIVE_INTERVAL=1h
LIVE_HISTORY_LIMIT=1000
LIVE_FORWARD_HORIZON=24
LIVE_MODEL=momentum_plus_roll_plus_interaction
LIVE_POSITION_FRACTION=0.05
LIVE_TAKE_PROFIT=0.05
LIVE_STOP_LOSS=0.025
LIVE_CYCLE_DELAY_SECONDS=5
LIVE_MIN_HISTORY_BARS=200
LIVE_TOP_K=1
LIVE_MAX_NEW_ENTRIES=1
LIVE_MAX_POSITIONS=1
